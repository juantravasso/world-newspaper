# Runtime connection used by the Next.js application.
# Use the pooled Neon connection string.
DATABASE_URL="postgresql://USER:PASSWORD@POOLER_HOST/DATABASE?sslmode=verify-full&channel_binding=require"

# Direct connection used by Prisma Migrate.
DIRECT_URL="postgresql://USER:PASSWORD@DIRECT_HOST/DATABASE?sslmode=verify-full&channel_binding=require"

# Generate a new random secret. Never commit the real value.
CRON_SECRET="replace-with-a-random-secret"

# Stories not seen during this period are removed.
STORY_RETENTION_DAYS="14"

# Public production URL without a trailing slash.
NEXT_PUBLIC_SITE_URL="https://your-production-domain.example"
